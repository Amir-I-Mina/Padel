<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Checkout</title>
    <link rel="stylesheet" href="/CSS/kevin.css">
</head>

<body>

<div class="navbar">
    <div class="logo">🎾 Yalla Padel</div>

    <div class="nav-links">
        <a href="/">Home</a>
    </div>
</div>

<h1>🧾 Checkout</h1>

<div class="box">

    <p><b>📍 Club:</b> <%= booking.club %></p>

    <p><b>🎾 Court:</b> <%= booking.court %></p>

    <p><b>📅 Date:</b> <%= booking.date %></p>

    <p><b>⏰ Time:</b> <%= booking.time %></p>

    <hr>

    <form action="/confirm-booking" method="POST">

        <input
            type="hidden"
            name="bookingId"
            value="<%= booking._id %>"
        >

        <label>💳 Payment Method</label>

        <select name="paymentMethod">
            <option value="Cash">Cash</option>
            <option value="Visa">Visa</option>
        </select>

        <br><br>

        <label>🏷 Promo Code</label>

        <input
            type="text"
            name="promoCode"
            placeholder="Enter promo code"
        >

        <br><br>

        <p>
            <b>💰 Total: <%= booking.price %> EGP</b>
        </p>

        <button
            type="submit"
            class="confirm-btn"
        >
            Confirm Booking
        </button>

    </form>

</div>

</body>
</html>