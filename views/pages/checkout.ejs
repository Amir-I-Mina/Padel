<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Yalla Padel | Checkout</title>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --navy: #1e293b;
            --navy-dark: #0f172a;
            --navy-mid: #334155;
            --blue: #2563eb;
            --blue-hover: #1d4ed8;
            --green: #10b981;
            --green-hover: #059669;
            --red: #ef4444;
            --text: #f8fafc;
            --text-muted: #94a3b8;
            --border: #334155;
            --card-bg: #1e293b;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background-color: #0f172a;
            color: var(--text);
            min-height: 100vh;
        }

        .navbar {
            background-color: var(--navy);
            padding: 15px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 5px 15px rgba(0,0,0,0.3);
            position: sticky;
            top: 0;
            z-index: 999;
        }

        .brand-text {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 26px;
            color: white;
            letter-spacing: 2px;
        }

        .nav-link {
            background: none;
            border: none;
            color: #94a3b8;
            font-family: 'DM Sans', sans-serif;
            font-size: 13px;
            font-weight: 600;
            letter-spacing: 1px;
            cursor: pointer;
            padding: 8px 14px;
            border-radius: 6px;
            transition: color 0.2s, background 0.2s;
        }

        .nav-link:hover { color: white; background: rgba(255,255,255,0.07); }

        .hero {
            background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
            padding: 50px 20px;
            text-align: center;
            border-bottom: 1px solid var(--border);
        }

        .hero-title {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 42px;
            letter-spacing: 4px;
            color: white;
        }

        .hero-subtitle {
            color: var(--text-muted);
            font-size: 15px;
            margin-top: 8px;
        }

        .steps {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 0;
            padding: 30px 20px 10px;
            max-width: 500px;
            margin: 0 auto;
        }

        .step {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 6px;
        }

        .step-circle {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: var(--navy-mid);
            border: 2px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            font-weight: 700;
            color: var(--text-muted);
            transition: all 0.3s;
        }

        .step.active .step-circle { background: var(--blue); border-color: var(--blue); color: white; }
        .step.done .step-circle { background: var(--green); border-color: var(--green); color: white; }

        .step-label {
            font-size: 11px;
            color: var(--text-muted);
            font-weight: 600;
            letter-spacing: 0.5px;
            text-transform: uppercase;
        }

        .step.active .step-label { color: var(--blue); }
        .step.done .step-label { color: var(--green); }

        .step-line {
            flex: 1;
            height: 2px;
            background: var(--border);
            margin-bottom: 20px;
            max-width: 80px;
        }

        .checkout-layout {
            display: grid;
            grid-template-columns: 1fr 400px;
            gap: 30px;
            max-width: 1100px;
            margin: 30px auto 60px;
            padding: 0 20px;
        }

        @media (max-width: 820px) {
            .checkout-layout { grid-template-columns: 1fr; }
        }

        .card {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 28px;
            margin-bottom: 20px;
        }

        .card-title {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 20px;
            letter-spacing: 2px;
            color: white;
            margin-bottom: 22px;
            padding-bottom: 14px;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .card-title span {
            width: 28px;
            height: 28px;
            background: var(--blue);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            font-family: 'DM Sans', sans-serif;
            font-weight: 700;
        }

        .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
        .form-group { margin-bottom: 18px; }
        .form-group.full { grid-column: 1 / -1; }

        label {
            display: block;
            font-size: 12px;
            font-weight: 600;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.8px;
            margin-bottom: 8px;
        }

        input, textarea, select {
            width: 100%;
            padding: 12px 14px;
            background: var(--navy-dark);
            border: 1px solid var(--border);
            border-radius: 8px;
            color: var(--text);
            font-family: 'DM Sans', sans-serif;
            font-size: 14px;
            transition: border-color 0.2s, box-shadow 0.2s;
            outline: none;
        }

        input:focus, textarea:focus, select:focus {
            border-color: var(--blue);
            box-shadow: 0 0 0 3px rgba(37,99,235,0.15);
        }

        input::placeholder, textarea::placeholder { color: #475569; }
        textarea { resize: vertical; min-height: 80px; }

        .error-msg { color: var(--red); font-size: 12px; margin-top: 5px; display: none; }
        .error-msg.show { display: block; }
        input.error, textarea.error { border-color: var(--red); }

        .order-item {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            padding: 14px 0;
            border-bottom: 1px solid var(--border);
            gap: 10px;
        }

        .order-item:last-child { border-bottom: none; }
        .order-item-info { flex: 1; }
        .order-item-name { font-size: 14px; font-weight: 600; color: var(--text); margin-bottom: 4px; }
        .order-item-details { font-size: 12px; color: var(--text-muted); }
        .order-item-price { font-size: 15px; font-weight: 700; color: var(--blue); white-space: nowrap; }
        .empty-cart-msg { text-align: center; color: var(--text-muted); padding: 30px 0; font-size: 14px; }

        .totals { margin-top: 10px; }

        .total-row {
            display: flex;
            justify-content: space-between;
            padding: 10px 0;
            font-size: 14px;
            color: var(--text-muted);
            border-bottom: 1px solid var(--border);
        }

        .total-row:last-child { border-bottom: none; }

        .total-row.grand {
            font-size: 18px;
            font-weight: 700;
            color: var(--text);
            padding-top: 16px;
        }

        .total-row.grand span:last-child { color: var(--blue); }

        .btn-place-order {
            width: 100%;
            padding: 16px;
            background: var(--green);
            color: white;
            border: none;
            border-radius: 10px;
            font-family: 'Bebas Neue', sans-serif;
            font-size: 20px;
            letter-spacing: 2px;
            cursor: pointer;
            transition: background 0.2s, transform 0.1s;
            margin-top: 20px;
        }

        .btn-place-order:hover { background: var(--green-hover); transform: translateY(-1px); }
        .btn-place-order:disabled { background: var(--navy-mid); color: var(--text-muted); cursor: not-allowed; transform: none; }

        .btn-back {
            width: 100%;
            padding: 12px;
            background: transparent;
            color: var(--text-muted);
            border: 1px solid var(--border);
            border-radius: 10px;
            font-family: 'DM Sans', sans-serif;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            margin-top: 10px;
        }

        .btn-back:hover { border-color: var(--text-muted); color: var(--text); }

        .success-screen {
            display: none;
            text-align: center;
            padding: 60px 20px;
            max-width: 500px;
            margin: 60px auto;
        }

        .success-screen.show { display: block; }

        .success-icon {
            width: 90px;
            height: 90px;
            background: rgba(16,185,129,0.15);
            border: 2px solid var(--green);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 28px;
            font-size: 40px;
            animation: pop 0.4s ease;
        }

        @keyframes pop {
            0% { transform: scale(0.5); opacity: 0; }
            80% { transform: scale(1.1); }
            100% { transform: scale(1); opacity: 1; }
        }

        .success-title {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 42px;
            letter-spacing: 3px;
            color: var(--green);
            margin-bottom: 12px;
        }

        .success-sub { color: var(--text-muted); font-size: 15px; line-height: 1.7; margin-bottom: 10px; }

        .order-id-badge {
            display: inline-block;
            background: var(--navy);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 10px 20px;
            font-size: 13px;
            color: var(--text-muted);
            margin: 16px 0 30px;
            font-family: monospace;
        }

        .order-id-badge strong { color: var(--blue); }

        .btn-continue {
            padding: 14px 36px;
            background: var(--blue);
            color: white;
            border: none;
            border-radius: 10px;
            font-family: 'Bebas Neue', sans-serif;
            font-size: 18px;
            letter-spacing: 2px;
            cursor: pointer;
            transition: background 0.2s;
        }

        .btn-continue:hover { background: var(--blue-hover); }

        .loading-spinner {
            display: none;
            width: 20px;
            height: 20px;
            border: 2px solid rgba(255,255,255,0.3);
            border-top-color: white;
            border-radius: 50%;
            animation: spin 0.7s linear infinite;
            margin: 0 auto;
        }

        @keyframes spin { to { transform: rotate(360deg); } }

        .secure-badge {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            font-size: 12px;
            color: var(--text-muted);
            margin-top: 14px;
        }
    </style>
</head>
<body>

    <div class="navbar">
        <div class="brand-text">Yalla Padel</div>
        <div>
            <button class="nav-link" onclick="location.href='/'">HOME</button>
            <button class="nav-link" onclick="location.href='/products/store'">STORE</button>
        </div>
    </div>

    <div class="hero">
        <h1 class="hero-title">Checkout</h1>
        <p class="hero-subtitle">Complete your order</p>
    </div>

    <div class="steps">
        <div class="step done" id="step1">
            <div class="step-circle">✓</div>
            <div class="step-label">Cart</div>
        </div>
        <div class="step-line"></div>
        <div class="step active" id="step2">
            <div class="step-circle">2</div>
            <div class="step-label">Details</div>
        </div>
        <div class="step-line"></div>
        <div class="step" id="step3">
            <div class="step-circle">3</div>
            <div class="step-label">Confirm</div>
        </div>
    </div>

    <div class="checkout-layout" id="checkoutLayout">
        <div>
            <div class="card">
                <div class="card-title"><span>1</span> Your Information</div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Full Name</label>
                        <input type="text" id="customerName" placeholder="Ahmed Mohamed">
                        <div class="error-msg" id="nameError">Please enter your name</div>
                    </div>
                    <div class="form-group">
                        <label>Phone Number</label>
                        <input type="tel" id="customerPhone" placeholder="01XXXXXXXXX">
                        <div class="error-msg" id="phoneError">Please enter a valid phone number</div>
                    </div>
                </div>
                <div class="form-group">
                    <label>Delivery Address</label>
                    <textarea id="customerAddress" placeholder="Street, Area, City..."></textarea>
                    <div class="error-msg" id="addressError">Please enter your delivery address</div>
                </div>
            </div>

            <div class="card">
                <div class="card-title"><span>2</span> Payment Method</div>
                <div class="form-group">
                    <label>Payment</label>
                    <select id="paymentMethod">
                        <option value="cash">💵 Cash on Delivery</option>
                        <option value="vodafone">📱 Vodafone Cash</option>
                        <option value="instapay">💳 InstaPay</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Notes (optional)</label>
                    <textarea id="orderNotes" placeholder="Any special instructions..."></textarea>
                </div>
            </div>
        </div>

        <div>
            <div class="card">
                <div class="card-title"><span>3</span> Order Summary</div>
                <div id="orderItemsList">
                    <p class="empty-cart-msg">Your cart is empty</p>
                </div>
                <div class="totals" id="orderTotals" style="display:none;">
                    <div class="total-row">
                        <span>Subtotal</span>
                        <span id="subtotalVal">0 EGP</span>
                    </div>
                    <div class="total-row">
                        <span>Delivery</span>
                        <span id="deliveryVal">60 EGP</span>
                    </div>
                    <div class="total-row grand">
                        <span>Total</span>
                        <span id="totalVal">0 EGP</span>
                    </div>
                </div>
                <button class="btn-place-order" id="placeOrderBtn" onclick="placeOrder()">PLACE ORDER</button>
                <div class="loading-spinner" id="loadingSpinner"></div>
                <button class="btn-back" onclick="location.href='/products/store'">← Back to Store</button>
                <div class="secure-badge">🔒 Secure checkout</div>
            </div>
        </div>
    </div>

    <div class="success-screen" id="successScreen">
        <div class="success-icon">✓</div>
        <div class="success-title">Order Placed!</div>
        <p class="success-sub">Thank you! Your order has been received and will be delivered soon.</p>
        <div class="order-id-badge">Order ID: <strong id="successOrderId">—</strong></div>
        <br>
        <button class="btn-continue" onclick="location.href='/'">CONTINUE SHOPPING</button>
    </div>

    <script>
        let cart = [];

        function loadCheckout() {
            const saved = localStorage.getItem('padelCart');
            if (saved) cart = JSON.parse(saved);

            const list = document.getElementById('orderItemsList');
            const totals = document.getElementById('orderTotals');
            const btn = document.getElementById('placeOrderBtn');

            if (cart.length === 0) {
                list.innerHTML = '<p class="empty-cart-msg">Your cart is empty</p>';
                btn.disabled = true;
                return;
            }

            let html = '';
            let subtotal = 0;

            cart.forEach(item => {
                const itemTotal = item.price * item.quantity;
                subtotal += itemTotal;
                html += `
                    <div class="order-item">
                        <div class="order-item-info">
                            <div class="order-item-name">${item.name}</div>
                            <div class="order-item-details">
                                Qty: ${item.quantity}
                                ${item.options ? ' · ' + item.options : ''}
                            </div>
                        </div>
                        <div class="order-item-price">${itemTotal.toLocaleString()} EGP</div>
                    </div>
                `;
            });

            const deliveryFee = subtotal >= 2000 ? 0 : 60;
            const finalTotal = subtotal + deliveryFee;

            list.innerHTML = html;
            totals.style.display = 'block';
            document.getElementById('subtotalVal').innerText = subtotal.toLocaleString() + ' EGP';
            document.getElementById('deliveryVal').innerText = deliveryFee === 0 ? 'Free 🎉' : deliveryFee + ' EGP';
            document.getElementById('totalVal').innerText = finalTotal.toLocaleString() + ' EGP';
        }

        function validate() {
            let valid = true;
            const name = document.getElementById('customerName').value.trim();
            const phone = document.getElementById('customerPhone').value.trim();
            const address = document.getElementById('customerAddress').value.trim();

            document.querySelectorAll('.error-msg').forEach(e => e.classList.remove('show'));
            document.querySelectorAll('input, textarea').forEach(e => e.classList.remove('error'));

            if (name.length < 3) {
                document.getElementById('nameError').classList.add('show');
                document.getElementById('customerName').classList.add('error');
                valid = false;
            }

            const phoneRegex = /^[0-9]{10,15}$/;
            if (!phoneRegex.test(phone)) {
                document.getElementById('phoneError').classList.add('show');
                document.getElementById('customerPhone').classList.add('error');
                valid = false;
            }

            if (address.length < 5) {
                document.getElementById('addressError').classList.add('show');
                document.getElementById('customerAddress').classList.add('error');
                valid = false;
            }

            return valid;
        }

        async function placeOrder() {
            if (cart.length === 0) { alert('Your cart is empty!'); return; }
            if (!validate()) return;

            const btn = document.getElementById('placeOrderBtn');
            const spinner = document.getElementById('loadingSpinner');

            btn.style.display = 'none';
            spinner.style.display = 'block';

            const subtotal = cart.reduce((sum, item) => sum + item.price * item.quantity, 0);
            const deliveryFee = subtotal >= 2000 ? 0 : 60;
            const finalTotal = subtotal + deliveryFee;

            const orderData = {
                items: cart,
                total: finalTotal,
                deliveryFee: deliveryFee,
                customer: {
                    name: document.getElementById('customerName').value.trim(),
                    phone: document.getElementById('customerPhone').value.trim(),
                    address: document.getElementById('customerAddress').value.trim()
                },
                paymentMethod: document.getElementById('paymentMethod').value,
                notes: document.getElementById('orderNotes').value.trim()
            };

            try {
                const response = await fetch('/orders', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(orderData)
                });

                const data = await response.json();

                if (data.success) {
                    localStorage.removeItem('padelCart');
                    document.getElementById('checkoutLayout').style.display = 'none';
                    document.querySelector('.steps').style.display = 'none';
                    document.getElementById('successScreen').classList.add('show');
                    document.getElementById('successOrderId').innerText = data.orderId;
                    document.getElementById('step3').classList.add('active');
                } else {
                    alert('Something went wrong: ' + data.message);
                    btn.style.display = 'block';
                    spinner.style.display = 'none';
                }
            } catch (err) {
                alert('Connection error. Please try again.');
                btn.style.display = 'block';
                spinner.style.display = 'none';
            }
        }

        loadCheckout();
    </script>

</body>
</html>