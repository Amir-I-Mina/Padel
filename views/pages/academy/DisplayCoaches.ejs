<!DOCTYPE html>
<html>
<head>
    <title>Coaches</title>

    <link rel="stylesheet" href="/CSS/coach.css">
</head>

<body>

<div class="navbar">
    <div class="logo">Yalla Padel</div>

    <div class="nav-links">
        <a href="/academy">Home</a>
        <a href="/academy/dashboard">Dashboard</a>
    </div>
</div>


<div class="hero">

    <a href="/academy" class="back">← BACK TO LIST</a>

    <h1>PADEL ACADEMY</h1>

    <p>Select your coach and improve your skills.</p>

</div>


<!-- COACH LIST (EJS RENDERED) -->
<div class="coach-container">

    <% if (coaches && coaches.length > 0) { %>

        <% coaches.forEach(coach => { %>

            <div class="tournament-card">

                <h3><%= coach.name %></h3>

                <p>Age: <%= coach.age %></p>
                <p>Experience: <%= coach.experience %></p>
                <p>Phone: <%= coach.phone %></p>
                <p>Location: <%= coach.location %></p>

                <p>Days: <%= coach.availableDays %></p>
                <p>Time: <%= coach.availableTimes %></p>

                <!-- BOOK BUTTON -->
                <form action="/academy/bookings" method="POST">

                    <input type="hidden" name="coachId" value="<%= coach._id %>">
                    <input type="hidden" name="location" value="<%= coach.location %>">

                    <button type="submit">Book Now</button>

                </form>

            </div>

        <% }) %>

    <% } else { %>

        <p>No coaches found.</p>

    <% } %>

</div>


<!-- FOOTER -->
<div class="footer" id="contact">

    <div class="footer-left">
        <h3>HPadel</h3>
        <p>Email: info@hpadel.com</p>
        <p>Phone: +20 123 456 789</p>
    </div>

    <div class="footer-right">
        <h4>Follow us</h4>

        <div class="socials">
            <a href="#"><img src="images/facee.jpeg"></a>
            <a href="#"><img src="images/instaaa.jpeg"></a>
        </div>
    </div>

</div>

</body>
</html>