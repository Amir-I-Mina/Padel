<!DOCTYPE html>
<html>
<head>
  <title>Training Payment</title>
  <link rel="stylesheet" href="/CSS/paymentAcademy.css">
</head>
<body>

<div class="navbar">
  <div class="logo">Yalla Padel</div>
  <div class="nav-links">
    <a href="/academy">Home</a>
  </div>
</div>

<div class="page-container">
  <div class="info-section">
    <h2>Confirm Your Booking</h2>
    <p>Please complete payment before your booking is confirmed.</p>
  </div>

 <div class="payment-container">
  <h2>Payment Details</h2>
  <form id="paymentForm" method="POST">
    <!-- Hidden booking fields -->
    <input type="hidden" name="coachId" value="<%= coach._id %>">
    <input type="hidden" name="coachName" value="<%= coach.name %>">
    <input type="hidden" name="trainingType" value="<%= type %>">
    <input type="hidden" name="day" value="<%= coach.availableDays[0] %>">
    <input type="hidden" name="time" value="<%= coach.availableTimes[0] %>">
    <input type="hidden" name="location" value="<%= coach.location %>">

    <!-- Cardholder Name -->
    <label for="cardName">Cardholder Name</label>
    <input type="text" id="cardName" placeholder="John Doe" required>

    <!-- Card Number -->
    <label for="cardNumber">Card Number</label>
    <input type="text" id="cardNumber" placeholder="1234 5678 9012 3456" required>

    <!-- Expiry & CVV side by side -->
    <div class="row">
      <div class="col">
        <label for="expiry">Expiry (MM/YY)</label>
        <input type="text" id="expiry" placeholder="MM/YY" required>
      </div>
      <div class="col">
        <label for="cvv">CVV</label>
        <input type="text" id="cvv" placeholder="123" required>
      </div>
    </div>

    <button type="submit">Pay & Confirm Booking</button>
  </form>

  <div id="confirmationMessage" class="confirmation">
  </div>
</div>

<script src="/js/coaches.js"></script>
</body>
</html>
