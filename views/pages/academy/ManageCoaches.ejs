<!DOCTYPE html>
<html>
<head>
    <title>Manage Coaches</title>
    <link rel="stylesheet" href="/CSS/ManageCoaches.css">
</head>

<body>

<div class="navbar">
    <div class="logo">Yalla Padel</div>

    <div class="nav-links">
        <a href="/admin/dashboard">HOME</a>
        <a href="/academy/admin/coaches-page">LIST OF COACHES</a>
    </div>
</div>

<div class="hero">
    <a href="/admin/academy" class="back">← BACK TO LIST</a>
    <h1>MANAGE COACHES</h1>
</div>

<div class="top-bar">
    <button id="addCoachBtn">+ Add Coach</button>
</div>

<div class="dashboardContainer">
    <% if (coaches && coaches.length > 0) { %>
        <% coaches.forEach(coach => { %>
            <div class="coach-card">
                <div class="menu-container">
                    <span class="menu-dots">⋮</span>
                    <div class="dropdown-menu">
                        <button 
                            class="edit-btn"
                            data-id="<%= coach._id %>"
                            data-name="<%= coach.name %>"
                            data-age="<%= coach.age %>"
                            data-phone="<%= coach.phone %>"
                            data-location="<%= coach.location %>"
                            data-experience="<%= coach.experience %>"
                            data-days="<%= coach.availableDays %>"
                            data-times="<%= coach.availableTimes %>"
                            data-type="<%= coach.trainingType %>"
                            data-salary="<%= coach.salary %>">
                            Edit
                        </button>
                        <button class="delete-btn" data-id="<%= coach._id %>">Delete</button>
                    </div>
                </div>

                <h3><%= coach.name %></h3>
                <p>Age: <%= coach.age %></p>
                <p>Phone: <%= coach.phone %></p>
                <p>Location: <%= coach.location %></p>
                <p>Experience: <%= coach.experience %></p>
                <p>Days: <%= coach.availableDays %></p>
                <p>Time: <%= coach.availableTimes %></p>
                <p>Type: <%= coach.trainingType %></p>
                <p>Salary: <%= coach.salary %></p>
            </div>
        <% }) %>
    <% } else { %>
        <p>No coaches available.</p>
    <% } %>
</div>


<div id="deleteModal" class="delete-modal" style="display: none;">
    <div class="delete-modal-content">
        <h3>Delete Coach</h3>
        <p>Are you sure you want to delete this coach?</p>
        <div class="delete-modal-buttons">
            <button id="confirmDelete" class="btn-yes">Yes, Delete</button>
            <button id="cancelDelete" class="btn-no">Cancel</button>
        </div>
    </div>
</div>


<div id="coachFormContainer" class="form-container" style="display:none;">
    <h2 id="formTitle">Add Coach</h2>
    <form id="coachForm" action="/academy/admin/Add-coaches" method="POST">
        <label>Coach Name</label>
        <input type="text" id="name" name="name">
        <span class="nameError"></span>

        <label>Age</label>
        <input type="number" id="age" name="age">
        <span class="ageError"></span>

        <label>Phone</label>
        <input type="text" id="phone" name="phone">
        <span class="phoneError"></span>

        <label>Location</label>
        <select id="location" name="location" required>
        <option disabled selected>Choose location</option>
        <option value="Smash Club">Smash Club</option>
        <option value="Cairo International Stadium">Cairo International Stadium</option>
        <option value="HPark">HPark</option>
        <option value="Wadi Degla">Wadi Degla</option>
        <option value="Shams Club">Shams Club</option>
        </select>

        <label>Experience</label>
        <input type="text" id="experience" name="experience">
        <span class="experienceError"></span>

        <label>Available Days</label>
        <select id="availableDays" name="availableDays" required>
        <option disabled selected>Choose available days</option>
        <option value="Monday-Wednesday">Monday-Wednesday</option>
        <option value="Tuesday-Thursday">Tuesday-Thursday</option>
        <option value="Thursday-Saturday">Thursday-Saturday</option>
        </select>
        <span class="daysError"></span>


        <label>Available Times</label>
        <select id="availableTimes" name="availableTimes" required>
        <option disabled selected>Choose available times</option>
        <option value="6-7">6:00 PM-7:00 PM</option>
        <option value="7-8">7:00 PM-8:00 PM</option>
        <option value="8-9">8:00 PM-9:00 PM</option>
        </select>
        <span class="timesError"></span>

        <label>Salary</label>
        <input type="number" id="salary" name="salary">
        <span class="salaryError"></span>

        <label>Training Type</label>
        <select id="trainingType" name="trainingType">
            <option value="private">Private</option>
            <option value="group">Group</option>
        </select>

        <button type="submit">Save Coach</button>
        <button type="button" id="closeForm">Cancel</button>
    </form>
</div>


<script src="/js/ManageCoaches.js"></script>

</body>
</html>