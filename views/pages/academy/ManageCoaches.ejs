<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="../css/ManageCoaches.css">
</head>

<body>

<div class="navbar">
    <div class="logo">Yalla Padel</div>

    <div class="nav-links">
        <a href="/home">HOME</a>
        <a href="/admin/list-coaches">LIST OF COACHES</a>
    </div>
</div>

<div class="hero">
    <a href="/admin/menu" class="back">← BACK TO LIST</a>
    <h1>MANAGE COACHES</h1>
</div>

<div class="top-bar">
    <button class="addCoachBtn">+ Add Coach</button>
</div>

<div class="dashboardContainer">
    <% if (coaches && coaches.length > 0) { %>
        <% coaches.forEach(coach => { %>
            <div class="coach-card" style="position:relative;">
                <div class="menu">
                    ⋮
                    <div class="menu-options">
                        <p class="edit">Edit</p>
                        <p class="delete">Delete</p>
                    </div>
                </div>

                <div class="Name">Coach Name: <span class="name"><%= coach.name %></span></div>
                <p>Phone: <span class="phone"><%= coach.phone %></span></p>
                <p>Location: <span class="location"><%= coach.location %></span></p>
                <p>Days: <span class="days"><%= coach.days %></span></p>
                <p>Time: <span class="time"><%= coach.time %></span></p>
                <p>Salary: <span class="salary"><%= coach.salary %></span></p>
            </div>
        <% }) %>
    <% } else { %>
        <p>No coaches available.</p>
    <% } %>
</div>

<div id="coach" class="form-container" style="display:none;">
    <h2>Add Coach</h2>
    <form class="coachForm" method="POST" action="/coaches">
        <label for="name">Coach Name</label>
        <input type="text" id="name" name="name" placeholder="Enter coach name">
        <span class="nameError"></span>

        <label for="phone">Phone</label>
        <input type="text" id="phone" name="phone" placeholder="Enter phone number">
        <span class="phoneError"></span>

        <label for="experience">Experience</label>
        <input type="text" id="experience" name="experience" placeholder="Years of experience">
        <span class="ExError"></span>

        <label for="location">Location</label>
        <input type="text" id="location" name="location" placeholder="Enter location">
        <span class="LocError"></span>

        <label for="days">Days</label>
        <input type="text" id="days" name="days" placeholder="e.g. Sunday, Tuesday">
        <span class="DayError"></span>

        <label for="time">Time</label>
        <input type="text" id="time" name="time" placeholder="e.g. 6 PM - 8 PM">
        <span class="timeError"></span>

        <label for="salary">Salary</label>
        <input type="text" id="salary" name="salary" placeholder="Enter salary">
        <span class="SalaryError"></span>

        <button type="submit" id="saveCoach">Save</button>
    </form>
</div>

<script src="../js/ManageCoaches.js"></script>
</body>
</html>
