<!DOCTYPE html>
<html>
<head>
<link rel="stylesheet" href="/CSS/home.css">
</head>

<body>


<div class="navbar">
    <div class="logo"> Yalla Padel </div>

    <div class="nav-links">
        <a href="#home">Home</a>
        <a href="#about">About</a>
        <a href="#contact">Contact</a>
        <% if (!user) { %>
    <a href="/login" class="login-btn">Login</a>
<% } else { %>
    <a href="/logout" class="login-btn">Logout</a>
<% } %>
    </div>
</div>

   
    

<div class="slider" id="home">


    <div class="slides" id="slides">

        <div class="slide">
            <img src="/images/bcourt.png">
           
        </div>

        <div class="slide">
            <img src="/images/Gemini_Generated_Image_g5b0p8g5b0p8g5b0.png">
            
        </div>

        <div class="slide">
            <img src="/images/Gemini_Generated_Image_kbttk8kbttk8kbtt.png">
            
        </div>

    </div>
    <div class="slider-overlay">
        <h1>Play. Compete. Improve.</h1>
        <p>Book courts and join the best padel experience.</p>
    </div>
</div>

</div>


<div class="container">

<% if (user) { %>
    <h2>Hey <%= user.username %></h2>
<% } %>

     
    <div class="about" id="about">
        <h3>About Us</h3>
        <p>
            Welcome to Yalla Padel! We provide the best padel experience by allowing you
            to book courts, join tournaments, browse our store, and connect with players.
            Our goal is to make sports more accessible and fun for everyone.
        </p>
    </div>

    <h3>What do you need?</h3>

   <div class="grid">
        <div class="card" style="background-image:url('../images/bcourt.png')">
           <a href="/courts">
            <div class="card-overlay">Book a court</div>
        </a>
        </div>

            <div class="card" style="background-image:url('/images/Gemini_Generated_Image_h5nhuph5nhuph5nh.png')">
                        <a href="/tournaments" style="text-decoration: none; color: inherit;">
                <div class="card-overlay">Tournaments</div>
            </a>

            </div>

        <div class="card" style="background-image:url('../images/Gemini_Generated_Image_kbttk8kbttk8kbtt.png')">
            <a href="/padelllllll">
            <div class="card-overlay">Store</div>
            </a>
        
        </div>

        <div class="card" style="background-image:url('../images/padel\ \(2\).jpeg')">
           <a href="/academy">
            <div class="card-overlay">Academy</div>
        </a>
        </div>
    </div>

</div>

<div class="footer" id="contact">

    <div class="footer-left">
        <h3>Yalla padel</h3>
        <p>Email: info@hpadel.com</p>
        <p>Phone: +20 123 456 789</p>
    </div>

    <div class="footer-right">
        <h4>Follow us</h4>

        <div class="socials">
            <a href="#"><img src="/images/facee.jpeg" ></a>
            <a href="#"><img src="/images/instaaa.jpeg"></a>
        </div>
    </div>

</div>

<script src="/js/home.js">
    
</script>


</body>
</html>