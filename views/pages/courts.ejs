<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Padel Court Booking</title>
    <link rel="stylesheet" href="/CSS/kevin.css">
</head>

<body>

<div class="navbar">
    <div class="logo">Yalla Padel</div>

    <div class="nav-links">
        <a href="/">Home</a>
    </div>
</div>

<h1>🎾 BOOK COURTS</h1>

<h2 style="text-align:center">
    Club: <%= club %>
</h2>

<div style="text-align:center; margin-bottom:20px;">
    <iframe
        src="<%= mapUrl %>"
        width="700"
        height="350"
        style="border:0;"
        loading="lazy">
    </iframe>
</div>

<% if (typeof error !== 'undefined' && error !== null && error !== "") { %>
    <p style="color:red;text-align:center">
        <%= error %>
    </p>
<% } %>

<div style="text-align:center;margin-bottom:20px;">
<form action="/court/createbooking" method="POST">
        <input type="hidden" name="club" value="<%= club %>">

        <label>Select Court</label>

        <select name="court" required>
            <option value="">Choose Court</option>
            <option value="Court 1">Court 1</option>
            <option value="Court 2">Court 2</option>
            <option value="Court 3">Court 3</option>
        </select>

        <br><br>

        <label>Select Date</label>

        <input
            type="date"
            name="date"
            id="dateInput"
            required
        >

        <br><br>

        <label>Select Time</label>

        <select name="time" required>
            <option value="">Choose Time</option>
            <option value="10:00">10 AM</option>
            <option value="11:00">11 AM</option>
            <option value="12:00">12 PM</option>
            <option value="13:00">1 PM</option>
            <option value="14:00">2 PM</option>
            <option value="15:00">3 PM</option>
            <option value="16:00">4 PM</option>
            <option value="17:00">5 PM</option>
            <option value="18:00">6 PM</option>
            <option value="19:00">7 PM</option>
            <option value="20:00">8 PM</option>
            <option value="21:00">9 PM</option>
            <option value="22:00">10 PM</option>
        </select>

        <br><br>

        <button type="submit">
            Continue To Checkout
        </button>

    </form>
</div>

<script>
    document.getElementById("dateInput").min =
        new Date().toISOString().split("T")[0];
</script>

</body>
</html>