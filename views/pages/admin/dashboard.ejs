<!DOCTYPE html>
<html>
<head>
    <title>Admin Dashboard</title>
    <link rel="stylesheet" href="/CSS/admin-dashboard.css">
</head>
<body>

<div class="navbar">
    <div class="logo">Yalla Padel Admin</div>

    <div class="admin-info">
        <img
            src="<%= user.profilePicture %>"
            alt="Admin"
            class="admin-profile">

        <span><%= user.username %></span>

        <a href="/logout" class="logout-btn">Logout</a>
    </div>
</div>

<div class="container">

    <h1>Welcome, <%= user.username %></h1>
    <p class="subtitle">
        Manage all Yalla Padel services from one place.
    </p>

    <div class="dashboard-grid">

       <a href="/admin/academy" class="card">
    <h2>Academy</h2>
    <p>Manage coaches and academy services.</p>
</a>

        <a href="/court/admin/admin" class="card">
            <h2>Courts</h2>
            <p>Manage courts, bookings and pricing.</p>
        </a>

      <a href="/admin/products" class="card">
    <h2>Store</h2>
    <p>Manage store products and inventory.</p>
</a>

        <a href="/admin/tournaments_admin" class="card">
            <h2>Tournaments</h2>
            <p>Manage tournaments and registrations.</p>
        </a>

       <a href="/admin/users" class="card">
    <h2>Users</h2>
    <p>Manage user accounts and permissions.</p>
</a>
<a href="/admin/home-management" class="card">
    <h2>Home Management</h2>
    <p>Manage homepage content and settings.</p>
</a>

    </div>

</div>


</body>
</html>