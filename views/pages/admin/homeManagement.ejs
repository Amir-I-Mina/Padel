<!DOCTYPE html>
<html>
<head>
    <title>Home Management</title>
</head>
<body>

<h1>Home Management</h1>

<form action="/admin/home-management" method="POST">

    <label>Homepage Title</label>
    <br>
    <input
        type="text"
        name="title"
        value="<%= content.title %>">
    <br><br>

    <label>Homepage Subtitle</label>
    <br>
    <input
        type="text"
        name="subtitle"
        value="<%= content.subtitle %>">
    <br><br>

    <label>Announcement</label>
    <br>
    <textarea
        name="announcement"><%= content.announcement %></textarea>
    <br><br>

    <button type="submit">
        Save Changes
    </button>

</form>

<br>

<a href="/admin/dashboard">
    Back to Dashboard
</a>

</body>
</html>