<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Yalla Padel | Court Checkout</title>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --navy: #1e293b;
            --navy-dark: #0f172a;
            --navy-mid: #334155;
            --blue: #2563eb;
            --blue-hover: #1d4ed8;
            --green: #10b981;
            --green-hover: #059669;
            --red: #ef4444;
            --text: #f8fafc;
            --text-muted: #94a3b8;
            --border: #334155;
            --card-bg: #1e293b;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background-color: #0f172a;
            color: var(--text);
            min-height: 100vh;
        }

        .navbar {
            background-color: var(--navy);
            padding: 15px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 5px 15px rgba(0,0,0,0.3);
            position: sticky;
            top: 0;
            z-index: 999;
        }

        .brand-text {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 26px;
            color: white;
            letter-spacing: 2px;
        }

        .nav-link {
            background: none;
            border: none;
            color: #94a3b8;
            font-family: 'DM Sans', sans-serif;
            font-size: 13px;
            font-weight: 600;
            letter-spacing: 1px;
            cursor: pointer;
            padding: 8px 14px;
            border-radius: 6px;
            transition: color 0.2s, background 0.2s;
        }

        .nav-link:hover { color: white; background: rgba(255,255,255,0.07); }

        .hero {
            background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
            padding: 50px 20px;
            text-align: center;
            border-bottom: 1px solid var(--border);
        }

        .hero-title {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 42px;
            letter-spacing: 4px;
            color: white;
        }

        .hero-subtitle {
            color: var(--text-muted);
            font-size: 15px;
            margin-top: 8px;
        }

        .steps {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 0;
            padding: 30px 20px 10px;
            max-width: 500px;
            margin: 0 auto;
        }

        .step {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 6px;
        }

        .step-circle {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: var(--navy-mid);
            border: 2px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            font-weight: 700;
            color: var(--text-muted);
        }

        .step.active .step-circle { background: var(--blue); border-color: var(--blue); color: white; }
        .step.done .step-circle { background: var(--green); border-color: var(--green); color: white; }

        .step-label {
            font-size: 11px;
            color: var(--text-muted);
            font-weight: 600;
            letter-spacing: 0.5px;
            text-transform: uppercase;
        }

        .step.active .step-label { color: var(--blue); }
        .step.done .step-label { color: var(--green); }

        .step-line {
            flex: 1;
            height: 2px;
            background: var(--border);
            margin-bottom: 20px;
            max-width: 80px;
        }

        .checkout-layout {
            display: grid;
            grid-template-columns: 1fr 400px;
            gap: 30px;
            max-width: 1100px;
            margin: 30px auto 60px;
            padding: 0 20px;
        }

        @media (max-width: 820px) {
            .checkout-layout { grid-template-columns: 1fr; }
        }

        .card {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 28px;
            margin-bottom: 20px;
        }

        .card-title {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 20px;
            letter-spacing: 2px;
            color: white;
            margin-bottom: 22px;
            padding-bottom: 14px;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .card-title span {
            width: 28px;
            height: 28px;
            background: var(--blue);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            font-family: 'DM Sans', sans-serif;
            font-weight: 700;
        }

        .form-group { margin-bottom: 18px; }

        label {
            display: block;
            font-size: 12px;
            font-weight: 600;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.8px;
            margin-bottom: 8px;
        }

        input, select {
            width: 100%;
            padding: 12px 14px;
            background: var(--navy-dark);
            border: 1px solid var(--border);
            border-radius: 8px;
            color: var(--text);
            font-family: 'DM Sans', sans-serif;
            font-size: 14px;
            transition: border-color 0.2s, box-shadow 0.2s;
            outline: none;
        }

        input:focus, select:focus {
            border-color: var(--blue);
            box-shadow: 0 0 0 3px rgba(37,99,235,0.15);
        }

        input::placeholder { color: #475569; }

        .detail-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 0;
            border-bottom: 1px solid var(--border);
            font-size: 14px;
        }

        .detail-row:last-child { border-bottom: none; }
        .detail-label { color: var(--text-muted); font-weight: 600; }
        .detail-value { color: var(--text); font-weight: 600; }

        .total-row {
            display: flex;
            justify-content: space-between;
            padding: 10px 0;
            font-size: 14px;
            color: var(--text-muted);
            border-bottom: 1px solid var(--border);
        }

        .total-row:last-child { border-bottom: none; }

        .total-row.grand {
            font-size: 18px;
            font-weight: 700;
            color: var(--text);
            padding-top: 16px;
        }

        .total-row.grand span:last-child { color: var(--blue); }

        .alert {
            padding: 14px 18px;
            border-radius: 10px;
            font-size: 14px;
            font-weight: 500;
            margin-bottom: 20px;
        }

        .alert-success {
            background: rgba(16,185,129,0.15);
            border: 1px solid var(--green);
            color: var(--green);
        }

        .alert-error {
            background: rgba(239,68,68,0.15);
            border: 1px solid var(--red);
            color: var(--red);
        }

        .btn-confirm {
            width: 100%;
            padding: 16px;
            background: var(--green);
            color: white;
            border: none;
            border-radius: 10px;
            font-family: 'Bebas Neue', sans-serif;
            font-size: 20px;
            letter-spacing: 2px;
            cursor: pointer;
            transition: background 0.2s, transform 0.1s;
            margin-top: 20px;
        }

        .btn-confirm:hover { background: var(--green-hover); transform: translateY(-1px); }
        .btn-confirm:disabled { background: var(--navy-mid); color: var(--text-muted); cursor: not-allowed; transform: none; }

        .btn-back {
            width: 100%;
            padding: 12px;
            background: transparent;
            color: var(--text-muted);
            border: 1px solid var(--border);
            border-radius: 10px;
            font-family: 'DM Sans', sans-serif;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            margin-top: 10px;
        }

        .btn-back:hover { border-color: var(--text-muted); color: var(--text); }

        .secure-badge {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            font-size: 12px;
            color: var(--text-muted);
            margin-top: 14px;
        }

        .success-screen {
            display: none;
            text-align: center;
            padding: 60px 20px;
            max-width: 500px;
            margin: 60px auto;
        }

        .success-screen.show { display: block; }

        .success-icon {
            width: 90px;
            height: 90px;
            background: rgba(16,185,129,0.15);
            border: 2px solid var(--green);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 28px;
            font-size: 40px;
            animation: pop 0.4s ease;
        }

        @keyframes pop {
            0% { transform: scale(0.5); opacity: 0; }
            80% { transform: scale(1.1); }
            100% { transform: scale(1); opacity: 1; }
        }

        .success-title {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 42px;
            letter-spacing: 3px;
            color: var(--green);
            margin-bottom: 12px;
        }

        .success-sub {
            color: var(--text-muted);
            font-size: 15px;
            line-height: 1.7;
            margin-bottom: 10px;
        }

        .booking-id-badge {
            display: inline-block;
            background: var(--navy);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 10px 20px;
            font-size: 13px;
            color: var(--text-muted);
            margin: 16px 0 30px;
            font-family: monospace;
        }

        .booking-id-badge strong { color: var(--blue); }

        .btn-continue {
            padding: 14px 36px;
            background: var(--blue);
            color: white;
            border: none;
            border-radius: 10px;
            font-family: 'Bebas Neue', sans-serif;
            font-size: 18px;
            letter-spacing: 2px;
            cursor: pointer;
            transition: background 0.2s;
        }

        .btn-continue:hover { background: var(--blue-hover); }
    </style>
</head>
<body>

<div class="navbar">
    <div class="brand-text">🎾 Yalla Padel</div>
    <div>
        <button class="nav-link" onclick="location.href='/'">HOME</button>
    </div>
</div>

<div class="hero">
    <h1 class="hero-title">🧾 Checkout</h1>
    <p class="hero-subtitle">Complete your court booking</p>
</div>

<div class="steps">
    <div class="step done">
        <div class="step-circle">✓</div>
        <div class="step-label">Club</div>
    </div>
    <div class="step-line"></div>
    <div class="step done">
        <div class="step-circle">✓</div>
        <div class="step-label">Court</div>
    </div>
    <div class="step-line"></div>
    <div class="step active">
        <div class="step-circle">3</div>
        <div class="step-label">Confirm</div>
    </div>
</div>

<% if (typeof success !== "undefined" && success) { %>

    <!-- SUCCESS SCREEN -->
    <div class="success-screen show">
        <div class="success-icon">✓</div>
        <div class="success-title">Booking Confirmed!</div>
        <p class="success-sub">Your court has been booked successfully.<br>See you on the court! 🎾</p>
        <% if (booking) { %>
            <div class="booking-id-badge">Booking ID: <strong><%= booking._id %></strong></div>
        <% } %>
        <br>
        <button class="btn-continue" onclick="location.href='/'">BACK TO HOME</button>
    </div>

<% } else { %>

    <div class="checkout-layout">

        <div>

            <!-- ALERTS -->
            <% if (typeof error !== "undefined" && error !== null && error !== "") { %>
                <div class="alert alert-error">❌ <%= error %></div>
            <% } %>

            <% if (booking) { %>

                <!-- BOOKING DETAILS -->
                <div class="card">
                    <div class="card-title"><span>1</span> Booking Details</div>

                    <div class="detail-row">
                        <span class="detail-label">📍 Club</span>
                        <span class="detail-value"><%= booking.club %></span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">🎾 Court</span>
                        <span class="detail-value"><%= booking.court %></span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">📅 Date</span>
                        <span class="detail-value"><%= new Date(booking.date).toLocaleDateString('en-GB') %></span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">⏰ Time</span>
                        <span class="detail-value"><%= booking.time %></span>
                    </div>
                </div>

                <!-- PAYMENT -->
                <div class="card">
                    <div class="card-title"><span>2</span> Payment Method</div>

                    <form action="/court/confirm-booking" method="POST">
                        <input type="hidden" name="bookingId" value="<%= booking._id %>">

                        <div class="form-group">
                            <label>💳 Payment Method</label>
                            <select name="paymentMethod">
                                <option value="Cash">💵 Cash</option>
                                <option value="Credit Card">💳 Credit Card</option>
                                <option value="Debit Card">🏧 Debit Card</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label>🏷 Promo Code</label>
                            <input
                                type="text"
                                name="promoCode"
                                placeholder="Enter promo code (optional)"
                            >
                        </div>

                </div>

            </div>

            <% } else { %>
                <div class="card">
                    <p style="color: var(--text-muted); text-align:center; padding: 30px 0;">No booking found.</p>
                </div>
            <% } %>

        </div>

        <!-- RIGHT: ORDER SUMMARY -->
        <div>
            <% if (booking) { %>
            <div class="card">
                <div class="card-title"><span>3</span> Summary</div>

                <div class="total-row">
                    <span>Court Booking</span>
                    <span><%= booking.price.toLocaleString() %> EGP</span>
                </div>
                <div class="total-row grand">
                    <span>Total</span>
                    <span><%= booking.price.toLocaleString() %> EGP</span>
                </div>

                        <button
                            type="submit"
                            class="btn-confirm"
                            onclick="this.disabled=true; this.form.submit();"
                        >
                            CONFIRM BOOKING
                        </button>
                        </form>

                <button class="btn-back" onclick="location.href='/'">← Back to Home</button>
                <div class="secure-badge">🔒 Secure booking</div>
            </div>
            <% } %>
        </div>

    </div>

<% } %>

</body>
</html>