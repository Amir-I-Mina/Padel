<!DOCTYPE html>
<html>
<head>
    <title>Forgot Password</title>
</head>
<body>

<h2>Reset Password</h2>

<form action="/forgot-password" method="POST">

    <input
        type="tel"
        name="phone"
        placeholder="Phone Number"
        required>

    <br><br>

    <input
        type="password"
        name="password"
        placeholder="New Password"
        required>

    <br><br>

    <button type="submit">
        Reset Password
    </button>

</form>

<p>
    <a href="/login">Back to Login</a>
</p>

</body>
</html>