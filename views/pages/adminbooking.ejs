<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Admin Dashboard</title>
  <link rel="stylesheet" href="/CSS/admin.css">
</head>
<body>
  <div class="navbar">
    <div class="logo">🎾 Yalla Padel Admin</div>
    <div class="nav-links">
      <a href="/">Home</a>
    </div>
  </div>

  <h1>⚙️ Admin Dashboard</h1>

  <!-- ===== CLUB MANAGEMENT ===== -->
  <section>
    <h2>🏟 Manage Clubs</h2>

    <!-- Add Club -->
    <div class="form-box">
      <input type="text" id="newClubName" placeholder="Club name">
      <input type="number" id="newClubPrice" placeholder="Price">
      <input type="text" id="newClubImage" placeholder="Image URL">
      <input type="text" id="newClubMap" placeholder="Google Maps embed URL">
      <button onclick="addClub()">Add Club</button>
    </div>

    <!-- Existing Clubs -->
    <table>
      <thead>
        <tr>
          <th>Image</th>
          <th>Name</th>
          <th>Price</th>
          <th>Map</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody id="clubsTableBody">
        <% clubs.forEach(club => { %>
          <tr>
            <td><img src="<%= club.image %>" alt="<%= club.name %>" width="80"></td>
            <td><%= club.name %></td>
            <td><%= club.price %> EGP</td>
            <td>
              <iframe src="<%= club.mapUrl %>" width="200" height="100" style="border:0;" allowfullscreen></iframe>
            </td>
            <td>
              <button onclick="updateClubPrice('<%= club.name %>')">Update Price</button>
              <button onclick="removeClub('<%= club.name %>')">Remove</button>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </section>

  <!-- ===== PROMO MANAGEMENT ===== -->
  <section>
    <h2>🏷 Promo Codes</h2>
    <div class="form-box">
      <input type="text" id="promoCodeName" placeholder="Promo code">
      <input type="number" id="promoDiscount" placeholder="Discount %">
      <button onclick="addPromoCode()">Add Promo</button>
    </div>

    <table>
      <thead>
        <tr><th>Code</th><th>Discount</th><th>Actions</th></tr>
      </thead>
      <tbody id="promoTableBody">
        <% promoCodes.forEach(promo => { %>
          <tr>
            <td><%= promo.code %></td>
            <td><%= promo.discount %>%</td>
            <td><button onclick="removePromoCode('<%= promo.code %>')">Remove</button></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </section>

  <!-- ===== SLOT MANAGEMENT ===== -->
  <section>
    <h2>⏰ Manage Slots</h2>
    <select id="courtManageSelect">
      <option value="Court 1">Court 1</option>
      <option value="Court 2">Court 2</option>
      <option value="Court 3">Court 3</option>
    </select>
    <input type="text" id="timeSlotManage" placeholder="e.g. 10 AM">
    <button onclick="disableTimeSlot()">Disable</button>
    <button onclick="enableTimeSlot()">Enable</button>
    <button onclick="resetAllSlotsForCourt()">Reset Court</button>
    <button onclick="resetAllSlots()">Reset All</button>

    <div id="slotPreview"></div>
  </section>

  <!-- ===== BOOKINGS MANAGEMENT ===== -->
  <section>
    <h2>📅 Bookings</h2>
    <table>
      <thead>
        <tr><th>Club</th><th>Court</th><th>Date</th><th>Time</th><th>Status</th><th>Actions</th></tr>
      </thead>
      <tbody id="bookingsListAdmin">
        <% if (bookings.length === 0) { %>
          <tr><td colspan="6">No bookings yet</td></tr>
        <% } else { %>
          <% bookings.forEach(b => { %>
            <tr>
              <td><%= b.club %></td>
              <td><%= b.court %></td>
              <td><%= b.date %></td>
              <td><%= b.time %></td>
              <td><%= b.status %></td>
              <td>
                <form action="/admin/cancel-booking/<%= b._id %>" method="POST">
                  <button type="submit">Cancel</button>
                </form>
              </td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
    <form action="/admin/clear-bookings" method="POST">
      <button type="submit">Clear All Bookings</button>
    </form>
  </section>

  <script src="/js/script.js"></script>
</body>
</html>
