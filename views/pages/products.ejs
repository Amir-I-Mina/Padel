<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin | Manage Products</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        body { background-color: #0f172a; color: #f8fafc; font-family: Arial, sans-serif; }
        
        .admin-container { max-width: 1100px; margin: 40px auto; padding: 0 20px; }
        
        .admin-card {
            background: #1e293b;
            border: 1px solid #334155;
            border-radius: 14px;
            padding: 28px;
            margin-bottom: 30px;
        }

        .admin-card h2 {
            font-size: 22px;
            color: white;
            margin-bottom: 20px;
            padding-bottom: 12px;
            border-bottom: 1px solid #334155;
        }

        .form-group { margin-bottom: 16px; }

        .form-group label {
            display: block;
            font-size: 12px;
            font-weight: 600;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            margin-bottom: 8px;
        }

        .form-group input,
        .form-group select,
        .form-group textarea {
            width: 100%;
            padding: 10px 14px;
            background: #0f172a;
            border: 1px solid #334155;
            border-radius: 8px;
            color: #f8fafc;
            font-size: 14px;
            outline: none;
        }

        .form-group input:focus,
        .form-group select:focus {
            border-color: #2563eb;
        }

        .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

        .btn-add {
            background: #2563eb;
            color: white;
            padding: 12px 24px;
            border: none;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 700;
            cursor: pointer;
            text-transform: uppercase;
            transition: background 0.2s;
        }

        .btn-add:hover { background: #1d4ed8; }

        .product-item {
            background: #0f172a;
            border: 1px solid #334155;
            border-radius: 10px;
            padding: 16px;
            margin-bottom: 12px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 16px;
        }

        .product-item.out-of-stock { opacity: 0.6; border-color: #ef4444; }

        .product-item img {
            width: 60px;
            height: 60px;
            object-fit: cover;
            border-radius: 8px;
            background: #334155;
        }

        .product-info { flex: 1; }
        .product-info strong { font-size: 15px; color: white; }
        .product-info small { color: #94a3b8; font-size: 12px; display: block; margin-top: 4px; }

        .product-price { font-size: 16px; font-weight: 700; color: #2563eb; }

        .stock-badge {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 700;
            background: #10b981;
            color: white;
            margin-top: 6px;
        }

        .stock-badge.out { background: #ef4444; }

        .product-actions { display: flex; gap: 8px; flex-wrap: wrap; }

        .btn-stock {
            background: #f59e0b;
            color: white;
            padding: 7px 14px;
            border: none;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 700;
            cursor: pointer;
            transition: background 0.2s;
        }

        .btn-stock:hover { background: #d97706; }

        .btn-delete {
            background: #ef4444;
            color: white;
            padding: 7px 14px;
            border: none;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 700;
            cursor: pointer;
            transition: background 0.2s;
        }

        .btn-delete:hover { background: #dc2626; }

        .success-msg {
            background: #10b981;
            color: white;
            padding: 12px 20px;
            border-radius: 8px;
            margin-bottom: 20px;
            display: none;
        }

        .error-msg-box {
            background: #ef4444;
            color: white;
            padding: 12px 20px;
            border-radius: 8px;
            margin-bottom: 20px;
            display: none;
        }

        .no-products {
            text-align: center;
            color: #94a3b8;
            padding: 30px;
            font-size: 14px;
        }
    </style>
</head>
<body>

    <div class="navbar">
        <div class="brand-text">Yalla Padel</div>
        <div>
         <button class="nav-link" onclick="location.href='/products/store'">STORE</button>
        <button class="nav-link" onclick="location.href='/admin/dashboard'">HOME</button>
        </div>
    </div>

    <div class="hero">
        <h1 class="hero-title">Manage Products</h1>
        <p class="hero-subtitle">Add, edit, and manage store inventory</p>
    </div>

    <div class="admin-container">

        <!-- SUCCESS / ERROR MESSAGES -->
        <div class="success-msg" id="successMsg"></div>
        <div class="error-msg-box" id="errorMsg"></div>

        <!-- ADD PRODUCT FORM -->
        <div class="admin-card">
            <h2>➕ Add New Product</h2>
            <form id="addProductForm" enctype="multipart/form-data">
                <div class="form-row">
                    <div class="form-group">
                        <label>Product Name</label>
                        <input type="text" id="productName" placeholder="e.g., Padel Shoes" required>
                    </div>
                    <div class="form-group">
                        <label>Price (EGP)</label>
                        <input type="number" id="productPrice" placeholder="e.g., 1200" required>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Category</label>
                        <select id="productCategory">
                            <option value="general">General</option>
                            <option value="rackets">Rackets</option>
                            <option value="balls">Balls</option>
                            <option value="clothing">Clothing</option>
                            <option value="accessories">Accessories</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Has Size/Color Options?</label>
                        <select id="productHasOptions">
                            <option value="false">No</option>
                            <option value="true">Yes</option>
                        </select>
                    </div>
                </div>
                <div class="form-group">
                    <label>Description</label>
                    <input type="text" id="productDesc" placeholder="Short description">
                </div>
                <div class="form-group">
                    <label>Product Image</label>
                    <input type="file" id="productImage" accept="image/*">
                </div>
                <button type="button" class="btn-add" onclick="addProduct()">+ Add Product</button>
            </form>
        </div>

        <!-- PRODUCT LIST -->
        <div class="admin-card">
            <h2>📦 Existing Products</h2>
            <div id="adminProductList">
                <% if (products.length === 0) { %>
                    <p class="no-products">No products yet. Add your first product above!</p>
                <% } else { %>
                    <% products.forEach(function(p) { %>
                        <div class="product-item <%= p.inStock ? '' : 'out-of-stock' %>" id="item_<%= p._id %>">
                            <img src="<%= p.image %>" onerror="this.src='/images/placeholder.png'">
                            <div class="product-info">
                                <strong><%= p.name %></strong>
                                <small><%= p.desc %></small>
                                <small>Category: <%= p.category %></small>
                                <span class="stock-badge <%= p.inStock ? '' : 'out' %>">
                                    <%= p.inStock ? 'In Stock' : 'Out of Stock' %>
                                </span>
                            </div>
                            <div class="product-price"><%= p.price.toLocaleString() %> EGP</div>
                            <div class="product-actions">
                                <button class="btn-stock" onclick="toggleStock('<%= p._id %>')">
                                    <%= p.inStock ? 'Mark Out of Stock' : 'Mark In Stock' %>
                                </button>
                                <button class="btn-delete" onclick="deleteProduct('<%= p._id %>')">Delete</button>
                            </div>
                        </div>
                    <% }); %>
                <% } %>
            </div>
        </div>

    </div>

    <script>
        function showSuccess(msg) {
            const el = document.getElementById('successMsg');
            el.innerText = msg;
            el.style.display = 'block';
            setTimeout(() => el.style.display = 'none', 3000);
        }

        function showError(msg) {
            const el = document.getElementById('errorMsg');
            el.innerText = msg;
            el.style.display = 'block';
            setTimeout(() => el.style.display = 'none', 3000);
        }

        async function addProduct() {
            const name = document.getElementById('productName').value.trim();
            const price = document.getElementById('productPrice').value.trim();
            const desc = document.getElementById('productDesc').value.trim();
            const category = document.getElementById('productCategory').value;
            const hasOptions = document.getElementById('productHasOptions').value;
            const imageFile = document.getElementById('productImage').files[0];

            if (!name || !price) {
                showError('Name and price are required!');
                return;
            }

            const formData = new FormData();
            formData.append('name', name);
            formData.append('price', price);
            formData.append('desc', desc);
            formData.append('category', category);
            formData.append('hasOptions', hasOptions);
            if (imageFile) formData.append('image', imageFile);

            try {
                const response = await fetch('/admin/products/add', {
                    method: 'POST',
                    body: formData
                });

                const data = await response.json();

                if (data.success) {
                    showSuccess('Product added successfully!');
                    // clear form
                    document.getElementById('productName').value = '';
                    document.getElementById('productPrice').value = '';
                    document.getElementById('productDesc').value = '';
                    document.getElementById('productImage').value = '';
                    // reload page to show new product
                    setTimeout(() => location.reload(), 1000);
                } else {
                    showError(data.message);
                }
            } catch (err) {
                showError('Connection error. Please try again.');
            }
        }

        async function toggleStock(id) {
            try {
                const response = await fetch('/admin/products/toggle-stock/' + id, {
                    method: 'POST'
                });
                const data = await response.json();
                if (data.success) {
                    showSuccess(data.message);
                    setTimeout(() => location.reload(), 1000);
                } else {
                    showError(data.message);
                }
            } catch (err) {
                showError('Connection error.');
            }
        }

        async function deleteProduct(id) {
            if (!confirm('Are you sure you want to delete this product?')) return;

            try {
                const response = await fetch('/admin/products/delete/' + id, {
                    method: 'POST'
                });
                const data = await response.json();
                if (data.success) {
                    showSuccess('Product deleted!');
                    document.getElementById('item_' + id).remove();
                } else {
                    showError(data.message);
                }
            } catch (err) {
                showError('Connection error.');
            }
        }
    </script>

</body>
</html>