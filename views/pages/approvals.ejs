        <!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Approvals | Admin</title>
    <link rel="stylesheet" href="/tournament_admin.css">
</head>
<body>
    <nav class="navbar">
        <div class="brand-text">Yalla Padel</div>
        <div class="nav-links">
            <a class="nav-link" href="/">Home</a>
            <a class="nav-link" href="/tournaments">Tournaments</a>
            <a class="nav-link" href="/matches">Matches</a>
            <a class="nav-link" href="/leaderboard">Leaderboard</a>
            <a class="nav-link" href="/admin/tournaments">Admin</a>
        </div>
    </nav>

    <nav class="admin-subnav">
        <a href="/admin/tournaments" class="admin-tab">Tournaments</a>
        <a href="/admin/approvals" class="admin-tab active">Approvals</a>
        <a href="/admin/tree-editor" class="admin-tab">Tree Editor</a>
    </nav>
    <main class="container">
        <div class="panel">
            <h2>Pending Registrations</h2>
            <% if (registrations && registrations.length > 0) { %>
                <% registrations.forEach(reg => { %>
                    <div class="approval-card">
                        <span class="badge open">Tournament</span>
                        <h3><%= reg.teamName %></h3>
                        <p>Status: <%= reg.status %></p>
                        <p><small>ID: <%= reg._id %></small></p>
                        <div style="display:flex; gap:10px; margin-top:20px;">
                            <button class="btn-approve approval-action" data-approved="true">Approve</button>
                            <button class="btn-danger approval-action" data-approved="false">Reject</button>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <p style="text-align: center; color: #666;">No pending registrations</p>
            <% } %>
        </div>
    </main>
    <script src="/tournament_admin.js"></script>
</body>
</html>
    <div style="display:flex; gap:10px; margin-top:20px;">
                <button class="btn-approve" onclick="processApproval(this, true)">Approve</button>
                <button class="btn-danger" onclick="processApproval(this, false)">Reject</button>
            </div>
        </div>
    </main>
    <script src="tournament_admin.js"></script>
</body>
</html>