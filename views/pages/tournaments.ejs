<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tournaments | Padel Hub</title>
    <link rel="stylesheet" href="/CSS/bishoy.css">
    <link rel="stylesheet" href="/CSS/tournament.css">
</head>
<body class="tournaments-page">
    <nav class="navbar">
        <div class="brand-text">Yalla Padel</div>
        <div class="nav-links">
            <a class="nav-link" href="/home">Home</a>
            <a class="nav-link" href="/tournaments">Tournaments</a>
            <a class="nav-link" href="/matches">Matches</a>
            <a class="nav-link" href="/leaderboard">Leaderboard</a>
        </div>
    </nav>

    <section id="list-view">
        <div class="hero">
            <h1 class="hero-title">Padel Tournaments</h1>
            <p>Select your format and join the ranking.</p>
        </div>

        <div class="container">
            <div class="card-grid">
                <% if (typeof tournaments !== 'undefined' && tournaments.length) { %>
                    <% tournaments.forEach(function(t){ %>
                        <% const cardImg = t.image || (t.type === 'Solo' ? '/images/Gemini_Generated_Image_ohnunohnunohnuno.png' : '/images/Gemini_Generated_Image_g5b0p8g5b0p8g5b0.png'); %>
                        <% const regType = (t.type === "Solo") ? 'solo' : 'doubles'; %>
                        <div class="tournament-card">
                            <div class="card-image" style="background-image: url('<%= cardImg %>');"></div>
                            <div class="card-content">
                                <span class="status-badge"><%= t.status %></span>
                                <h2><%= t.name %></h2>
                                <p><%= t.type || '2v2 Team • 2 Players Required' %></p>
                                <button class="btn-action" onclick="goReg('<%= regType %>')">Register</button>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="tournament-card">
                        <div class="card-image" style="background-image: url('/images/Gemini_Generated_Image_g5b0p8g5b0p8g5b0.png');"></div>
                        <div class="card-content">
                            <span class="status-badge">OPEN</span>
                            <h2>Spring Doubles Cup</h2>
                            <p>2v2 Team • 2 Players Required</p>
                            <button class="btn-action" onclick="goReg('doubles')">Register Team</button>
                        </div>
                    </div>

                    <div class="tournament-card">
                        <div class="card-image" style="background-image: url('/images/Gemini_Generated_Image_ohnunohnunohnuno.png');"></div>
                        <div class="card-content">
                            <span class="status-badge">OPEN</span>
                            <h2>Solo Masters League</h2>
                            <p>1v1 Individual • 1 Player Only</p>
                            <button class="btn-action" onclick="goReg('solo')">Register Solo</button>
                        </div>
                    </div>
                <% } %>
            </div>
        </div>
    </section>

    <section id="details-view" class="section-hidden container" style="padding-top: 50px;">
        <button class="back-btn" onclick="show('list')">← BACK TO LIST</button>
        <div class="registration-box">
            <div class="form-info">
                <h2 id="title-display">Tournament</h2>
            </div>
            <div class="form-inputs">
                <form action="/tournaments" method="POST">
                    <label>Team Name</label>
                    <input name="teamName" type="text" class="input-field" required>
                    <label>Player 1</label>
                    <input name="player1" type="text" class="input-field" required>
                    <div id="player2-section">
                        <label>Player 2</label>
                        <input name="player2" type="text" class="input-field">
                    </div>
                    <button type="submit" class="btn-action">Submit Entry</button>
                </form>
            </div>
        </div>
    </section>

    <script src="/js/bishoy.js"></script>
</body>
</html>
