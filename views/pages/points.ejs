<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Leaderboard | Yalla Padel</title>
    <link rel="stylesheet" href="/bishoy.css">
    <link rel="stylesheet" href="/leaderboard.css">
</head>
<body>

    <nav class="navbar">
        <div class="brand-text">Yalla Padel</div>
        <div class="nav-links">
            <a class="nav-link" href="/">Home</a>
            <a class="nav-link" href="/tournaments">Tournaments</a>
            <a class="nav-link" href="/matches">Matches</a>
            <a class="nav-link" href="/leaderboard">Leaderboard</a>
            <a class="nav-link" href="/admin/tournaments">Admin</a>
        </div>
    </nav>

    <div class="container" style="padding-top: 50px;">
        <h1 style="text-align: center;">Leaderboard</h1>
        
        <table style="width:100%; border-collapse: collapse; margin-top: 20px; background: white;">
            <thead>
                <tr style="background: #0f172a; color: white;">
                    <th style="padding: 15px; text-align: left;">Rank</th>
                    <th style="padding: 15px; text-align: left;">Player/Team</th>
                    <th style="padding: 15px; text-align: left;">Points</th>
                </tr>
            </thead>
            <tbody>
                <tr style="border-bottom: 1px solid #ddd;">
                    <td style="padding: 15px;">1</td>
                    <td style="padding: 15px;">Smash Kings</td>
                    <td style="padding: 15px;">1500</td>
                </tr>
                <tr style="border-bottom: 1px solid #ddd;">
                    <td style="padding: 15px;">2</td>
                    <td style="padding: 15px;">Net Ninjas</td>
                    <td style="padding: 15px;">1250</td>
                </tr>
            </tbody>
        </table>
    </div>

</body>
</html>