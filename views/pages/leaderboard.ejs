<!DOCTYPE html>
<html>
<head>
<link rel="stylesheet" href="/CSS/bishoy.css">
<link rel="stylesheet" href="/CSS/leaderboard.css">
</head>
<body>
    <nav class="navbar">
        <div class="brand-text">Yalla Padel</div>
        <div class="nav-links">
            <a class="nav-link" href="/">Home</a>
            <a class="nav-link" href="/tournaments">Tournaments</a>
            <a class="nav-link" href="/matches">Matches</a>
            <a class="nav-link" href="/leaderboard">Leaderboard</a>
            <a class="nav-link" href="/admin/tournaments">Admin</a>
        </div>
    </nav>
    
    <div class="container" style="padding: 40px 20px;">
        <h1 style="text-align: center; margin-bottom: 40px;">🏆 Tournament Leaderboard</h1>
        
        <% if (teams && teams.length > 0) { %>
            <table class="leaderboard-table" style="max-width: 800px; margin: 0 auto; width: 100%; border-collapse: collapse; background: white; border-radius: 8px; overflow: hidden; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
                <thead>
                    <tr style="background-color: #0f172a; color: white;">
                        <th style="padding: 15px; text-align: center; width: 60px;">Rank</th>
                        <th style="padding: 15px; text-align: left;">Team Name</th>
                        <th style="padding: 15px; text-align: center;">Points</th>
                    </tr>
                </thead>
                <tbody>
                    <% teams.forEach((team, index) => { %>
                        <tr style="border-bottom: 1px solid #e2e8f0; <%= index === 0 ? 'background-color: #fef3c7;' : '' %>">
                            <td style="padding: 15px; text-align: center; font-weight: bold; color: #3b82f6;">
                                <% if (index === 0) { %>🥇<% } else if (index === 1) { %>🥈<% } else if (index === 2) { %>🥉<% } else { %>#<%= index + 1 %><% } %>
                            </td>
                            <td style="padding: 15px; font-weight: 500;">
                                <%= team.teamName %>
                            </td>
                            <td style="padding: 15px; text-align: center; font-weight: bold; color: #3b82f6;">
                                <%= team.points || 0 %>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        <% } else { %>
            <div style="text-align: center; padding: 60px 20px; color: #999;">
                <p style="font-size: 18px;">📊 No approved teams yet!</p>
                <p>Teams will appear here once they register and are approved by admins.</p>
            </div>
        <% } %>
    </div>
</body>
</html>