const express = require("express");
const router = express.Router();

const adminController = require("../controllers/adminController");

router.get("/products", adminController.manage_get_products);
router.get("/products/all", adminController.getAdminAllProducts);
router.post("/products/add", adminController.addProduct);
router.post("/products/update/:id", adminController.updateProduct);
router.post("/products/toggle-stock/:id", adminController.toggleStock);
router.post("/products/delete/:id", adminController.deleteProduct);

module.exports = router;